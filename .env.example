# Copy to .env or export these variables in your shell/deployment platform.
# Do not put real secrets in Git.

SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Agent entrance security. Required in prod.
AGENT_API_KEY=change-me-in-local-only
AGENT_RETRIEVAL_DEFAULT_MODE=hybrid_reranker

# Business database. local profile can use the H2 defaults instead.
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/spring_ai_demo?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&sslMode=PREFERRED
SPRING_DATASOURCE_USERNAME=spring_ai_app
SPRING_DATASOURCE_PASSWORD=replace-with-your-password

# DeepSeek ChatClient.
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY_FILE=/absolute/path/to/deepseek-apiKey.txt

# PGVector knowledge index.
PGVECTOR_ENABLED=false
PGVECTOR_JDBC_URL=jdbc:postgresql://localhost:5432/logistics_agent
PGVECTOR_USERNAME=logistics_agent
PGVECTOR_PASSWORD=replace-with-your-password
PGVECTOR_FAIL_FAST=false

# Local model switches.
LOCAL_EMBEDDING_PROVIDER=hashing
LOCAL_RERANKER_PROVIDER=lightweight
